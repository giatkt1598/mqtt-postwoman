{
  "name": "@mqtt-postwoman/server",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "test": "tsx --test test/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "migration:run": "tsx src/database/cli.ts run",
    "migration:revert": "tsx src/database/cli.ts revert",
    "migration:show": "tsx src/database/cli.ts show",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate src/database/migrations/Next -d src/database/data-source.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.4.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dayjs": "^1.11.21",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "mqtt": "^5.14.1",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.31",
    "ws": "^8.18.3",
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.10.1",
    "@types/ws": "^8.18.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
